# העתק ל-.env.local והשלימי מהקונסולה (Project settings → Your apps → Firebase SDK snippet).
# אחרי שינוי: הפעלה מחדש של `npm run dev`.
#
# פרודקשן (Node + `npm run build`): אם הבנייה רצה בלי המשתנים האלה, שימי את אותם ערכים
# בקובץ env של השרת (למשל server/.env) בשמות FIREBASE_* — השרת יחשוף אותם ב־GET /api/firebase-config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
