{
  "name": "idea-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n app,push -c auto \"vite --port 5174\" \"npm --prefix server run dev\"",
    "dev:app": "vite --port 5174",
    "dev:push": "npm --prefix server run dev",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "vite": "^6.0.0"
  }
}

