{
  "name": "idea-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n app,push -c auto \"vite --port 5174\" \"npm --prefix server run dev\"",
    "dev:app": "vite --port 5174",
    "dev:push": "npm --prefix server run dev",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && vite build",
    "start": "node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "sharp": "^0.34.5",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "html2pdf.js": "^0.14.0",
    "pdfjs-dist": "^5.7.284",
    "tesseract.js": "^7.0.0"
  }
}
