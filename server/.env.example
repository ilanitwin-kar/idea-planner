PORT=8787
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=REPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME

# אופציונלי: אותם ערכים כמו ב-Firebase Web App — כדי שהאפליקציה אחרי `npm run build` תקבל תצורה בלי משתני Vite בזמן build.
# אפשר גם להעביר כ-FIREBASE_* או כ-VITE_FIREBASE_* (מפריסה לשרת).
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_APP_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_MESSAGING_SENDER_ID=
#
# אבחון: אחרי הרצת השרת פתחי בדפדפן https://הדומיין-שלך/api/firebase-config/status
# — אמור להחזיר "ok":true. אם "missing" לא ריק, השרת לא קורא את הקובץ/משתני הסביבה.
